inherit cargo

DESCRIPTION="Lightweight, fast and secure chat application powered by WHY2 encryption"
HOMEPAGE="https://why2.satan.red"

MY_PN="why2-chat"
SRC_URI="https://crates.io/api/v1/crates/${MY_PN}/${PV}/download -> ${MY_PN}-${PV}.crate ${CARGO_CRATE_URIS}"
S="${WORKDIR}/${MY_PN}-${PV}"

LICENSE="GPL-3 0BSD Apache-2.0 Apache-2.0-with-LLVM-exceptions BSD BSD-2 BlueOak-1.0.0 CDLA-Permissive-2.0 ISC LGPL-2.1+ MIT MPL-2.0 Unicode-3.0 Unlicense ZLIB"
SLOT="0"
KEYWORDS="~amd64"

QA_FLAGS_IGNORED="usr/bin/why2 usr/bin/why2-server"
IUSE="+server"

DEPEND="media-libs/alsa-lib"
RDEPEND="${DEPEND}"
BDEPEND="virtual/pkgconfig"

src_unpack() {
	cargo_src_unpack
	tar xf "${DISTDIR}/${MY_PN}-${PV}.crate" -C "${WORKDIR}" || die
}

src_compile() {
	cargo_src_compile  # builds client (default features)
	if use server; then
	cargo_src_compile --bin why2-server --no-default-features --features server
	fi
}

src_install() {
	dobin "$(cargo_target_dir)/why2"
	use server && dobin "$(cargo_target_dir)/why2-server"
}
